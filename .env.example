# PostgreSQL connection string
DATABASE_URL="postgresql://polysiem:polysiem@localhost:5432/polysiem"

# 32+ byte hex secret used to derive encryption keys for integration credentials.
# Generate with: openssl rand -hex 32
APP_SECRET="change-me-generate-a-real-secret"

# Public URL of this PolySIEM instance (used for canonical/social links, MCP
# config snippets, and the Secure flag on session cookies). Production serves
# HTTPS by default, so prefer an https:// URL there.
APP_URL="http://localhost:3000"

# Built-in HTTPS (production standalone/Docker only; `npm run dev` stays HTTP).
# The server generates a self-signed certificate on first boot and admins can
# replace it under Settings → Web certificate.
# POLYSIEM_TLS=off          # serve plain HTTP instead (e.g. behind your own reverse proxy)
# POLYSIEM_CERT_DIR=        # certificate directory (default: <runtime>/data/certs)

# Release metadata used by Settings → About and Docker installs
POLYSIEM_GITHUB_REPOSITORY="Realynx/PolySIEM"
# POLYSIEM_IMAGE="ghcr.io/realynx/polysiem:latest"
# POLYSIEM_AUTO_UPDATE_CAPABLE=false # enables the isolated Linux update agent
# POLYSIEM_UPDATE_AGENT_TOKEN=""     # installer-generated; do not share

# Development helpers
# MOCK_AI=true            # /api/ai returns canned responses without a running Ollama
# POLYSIEM_DEMO_MODE=true  # enables mock-integration controls on deployed demo instances
# The dedicated public-demo launcher also sets POLYSIEM_DEMO_LOCKED=true and
# POLYSIEM_DEMO_AUTO_SETUP=true. Do not set those against a real PolySIEM database.
