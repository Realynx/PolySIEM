{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "PolySIEM currently requires a single replica because its background schedulers are process-local."
    },
    "podLabels": {
      "type": "object",
      "propertyNames": {
        "not": {
          "enum": [
            "app.kubernetes.io/name",
            "app.kubernetes.io/instance",
            "app.kubernetes.io/component"
          ]
        }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      },
      "required": ["repository", "pullPolicy"]
    },
    "config": {
      "type": "object",
      "properties": {
        "appUrl": { "type": "string", "minLength": 1 },
        "tls": { "type": "boolean" },
        "githubRepository": { "type": "string", "minLength": 1 },
        "databaseUrl": { "type": "string" },
        "appSecret": {
          "anyOf": [
            { "const": "" },
            { "type": "string", "minLength": 32 }
          ]
        }
      },
      "required": ["appUrl", "tls", "githubRepository"]
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": ["integer", "null"], "minimum": 30000, "maximum": 32767 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string", "pattern": "^/" },
                    "pathType": { "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string",
          "maxLength": 253,
          "pattern": "^$|^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
        },
        "keys": {
          "type": "object",
          "properties": {
            "appSecret": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
            "databaseUrl": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
            "databasePassword": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?[EPTGMK]i?$" }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string", "minLength": 1 },
            "database": { "type": "string", "minLength": 1 },
            "password": { "type": "string" }
          }
        }
      }
    },
    "migration": {
      "type": "object",
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "retryDelaySeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "rolloutRevision": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 10 }
  }
}
